# ai6 configuration — copied to ~/.config/ai6/config by install.sh.
#
# This file is sourced by the review bridges. Use conditional assignment (:=) so
# that values passed inline on the command line (e.g. AI6_REVIEWER_MODEL=... )
# still take precedence over what's set here.

# --- Reviewer when Claude builds (ask-glm.sh, via OpenCode) ---
# Any provider/model OpenCode can reach. Examples:
#   zai-coding-plan/glm-5.2      (Z.AI)
#   anthropic/claude-sonnet-4-6
#   openai/gpt-5
: "${AI6_REVIEWER_MODEL:=zai-coding-plan/glm-5.2}"

# OpenCode agent used for the review (read-only persona shipped with ai6).
: "${AI6_REVIEWER_AGENT:=ai6-reviewer}"

# --- Reviewer when the other model builds (ask-claude.sh, via Claude Code) ---
# A `claude --model` alias or full model id (e.g. opus, sonnet, claude-opus-4-8).
: "${AI6_CLAUDE_MODEL:=opus}"

# --- Reliability under concurrency (both bridges) ---
# A review can never hang forever: each attempt is bounded, retried, and degraded to
# a 'VERDICT: ERROR' if it can't complete.
: "${AI6_TIMEOUT:=300}"        # seconds per review attempt before it's killed
: "${AI6_RETRIES:=1}"          # extra attempts after the first (on timeout/failure)
: "${AI6_RETRY_DELAY:=3}"      # seconds between attempts
: "${AI6_SERIALIZE:=1}"        # 1 = only one review runs at a time across ALL projects
: "${AI6_LOCK_TIMEOUT:=900}"   # max seconds to wait for the serialization lock

# Large reviews auto-split into passes so the reviewer always sees every file in
# full (never silently truncated by a model's context window).
: "${AI6_MAX_CHARS:=200000}"   # approx max request size per pass, in bytes

# --- Security audit (the full /ai6-security scan) ---
# Uses its own agent persona by default (ai6-security-reviewer). Override either
# the model or the agent only if you know what you're doing — the wrong agent
# loses the section-aware audit rubric.
: "${AI6_SECURITY_MODEL:=${AI6_REVIEWER_MODEL}}"
: "${AI6_SECURITY_AGENT:=ai6-security-reviewer}"
# AI6_SECURITY_CHECKLIST: leave unset to use project's docs/SECURITY_CHECKLIST.md
# if present, otherwise the installed default. Set to an absolute path to override.

# Advanced: AI6_PLUGIN_TIMEOUT_MS overrides the OpenCode plugin's backstop (in ms).
# The plugin reads process.env (not this file), so set it in the environment OpenCode
# runs in. Leave unset to derive it from the values above.

export AI6_REVIEWER_MODEL AI6_REVIEWER_AGENT AI6_CLAUDE_MODEL
export AI6_TIMEOUT AI6_RETRIES AI6_RETRY_DELAY AI6_SERIALIZE AI6_LOCK_TIMEOUT AI6_MAX_CHARS
export AI6_SECURITY_MODEL AI6_SECURITY_AGENT AI6_SECURITY_CHECKLIST
