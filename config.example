# ai6 configuration — copied to ~/.config/ai6/config by install.sh.
#
# This file is sourced by the review bridges. Use conditional assignment (:=) so
# that values passed inline on the command line (e.g. AI6_REVIEWER_MODEL=... )
# still take precedence over what's set here.

# --- Reviewer when Claude builds (ask-glm.sh, via OpenCode) ---
# Any provider/model OpenCode can reach. Examples:
#   zai-coding-plan/glm-5.2      (Z.AI)
#   anthropic/claude-sonnet-4-6
#   openai/gpt-5
: "${AI6_REVIEWER_MODEL:=zai-coding-plan/glm-5.2}"

# OpenCode agent used for the review (read-only persona shipped with ai6).
: "${AI6_REVIEWER_AGENT:=ai6-reviewer}"

# --- Reviewer when the other model builds (ask-claude.sh, via Claude Code) ---
# A `claude --model` alias or full model id (e.g. opus, sonnet, claude-opus-4-8).
: "${AI6_CLAUDE_MODEL:=opus}"

export AI6_REVIEWER_MODEL AI6_REVIEWER_AGENT AI6_CLAUDE_MODEL
